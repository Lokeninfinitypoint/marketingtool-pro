---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="MarketingTool.Pro - 418+ AI Marketing Tools for Webflow">
  <Header slot="header" />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-20 px-4 bg-gradient-to-br from-blue-600 via-purple-600 to-pink-600">
    <div class="max-w-7xl mx-auto text-center text-white">
      <h1 class="text-5xl md:text-6xl font-bold mb-6">
        418+ AI Marketing Tools
        <span class="block mt-2">Directly in Webflow Designer</span>
      </h1>
      <p class="text-xl md:text-2xl mb-8 opacity-90">
        Access powerful AI marketing automation without leaving Webflow
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="https://webflow.com/apps" class="bg-white text-blue-600 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-gray-100 transition-colors shadow-lg">
          Install Extension
        </a>
        <a href="/dashboard" class="border-2 border-white text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-white/10 transition-colors">
          View All Tools
        </a>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-4xl font-bold text-center mb-12 text-gray-900">Everything You Need</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="text-5xl mb-4">🎯</div>
          <h3 class="text-xl font-semibold mb-3">Meta & Facebook Ads</h3>
          <p class="text-gray-600">50+ tools for campaign management, ad copy, audience building, and optimization</p>
        </div>
        <div class="text-center p-6">
          <div class="text-5xl mb-4">🔍</div>
          <h3 class="text-xl font-semibold mb-3">Google Ads & SEO</h3>
          <p class="text-gray-600">40+ tools for keyword research, ad preview, quality scores, and rankings</p>
        </div>
        <div class="text-center p-6">
          <div class="text-5xl mb-4">✍️</div>
          <h3 class="text-xl font-semibold mb-3">Content Generation</h3>
          <p class="text-gray-600">50+ tools for blog posts, social media, emails, and CMS bulk content</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold mb-6 text-gray-900">Ready to Transform Your Marketing?</h2>
      <p class="text-xl text-gray-600 mb-8">
        Join thousands of marketers using AI to automate and optimize their Webflow sites
      </p>
      <a href="https://webflow.com/apps" class="bg-blue-600 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-blue-700 transition-colors inline-block shadow-lg">
        Get Started Free
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer slot="footer" class="bg-gray-900 text-white py-12 px-4">
    <div class="max-w-7xl mx-auto text-center">
      <div class="mb-6">
        <span class="text-2xl font-bold">MarketingTool.Pro</span>
      </div>
      <p class="text-gray-400 mb-4">Operated by Infinity Solutions</p>
      <p class="text-gray-400 mb-6">Jaipur, Rajasthan, India 🇮🇳</p>
      <div class="flex justify-center space-x-6 text-sm">
        <a href="/privacy" class="text-gray-400 hover:text-white transition-colors">Privacy</a>
        <a href="/terms" class="text-gray-400 hover:text-white transition-colors">Terms</a>
        <a href="mailto:support@marketingtool.pro" class="text-gray-400 hover:text-white transition-colors">Support</a>
      </div>
    </div>
  </footer>
</BaseLayout>
