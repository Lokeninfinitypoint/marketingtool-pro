---
// Main Navigation Header Component - MarketingTool Pro Template
---

<header class="sticky top-0 z-50 w-full bg-gradient-to-r from-slate-950 via-purple-950 to-slate-950 border-b border-purple-500/10 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-2">
        <div class="text-2xl font-bold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">
          MarketingTool Pro
        </div>
      </a>

      <!-- Navigation Menu -->
      <nav class="hidden md:flex items-center space-x-1">

        <!-- Home -->
        <a href="/" class="px-4 py-2 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-colors text-sm font-medium">
          Home
        </a>

        <!-- Services Dropdown -->
        <div class="relative group">
          <button class="px-4 py-2 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-colors flex items-center space-x-1 text-sm font-medium">
            <span>Services</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="absolute left-0 mt-2 w-64 bg-slate-900 border border-purple-500/20 rounded-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2">
            <!-- Services Header -->
            <div class="px-4 py-2 border-b border-gray-800">
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Our Services</p>
            </div>

            <!-- Marketing Tools -->
            <a href="https://app.marketingtool.pro/tools" class="flex items-start px-4 py-3 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors group/item">
              <div class="mr-3 mt-0.5">
                <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium">All 418 Tools</p>
                <p class="text-xs text-gray-400 mt-0.5">Access every marketing tool</p>
              </div>
            </a>

            <!-- AI Tools -->
            <a href="https://app.marketingtool.pro/ai/content-generator" class="flex items-start px-4 py-3 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors group/item">
              <div class="mr-3 mt-0.5">
                <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium">AI Tools</p>
                <p class="text-xs text-gray-400 mt-0.5">Content generation & optimization</p>
              </div>
            </a>

            <!-- Dashboard -->
            <a href="https://app.marketingtool.pro" class="flex items-start px-4 py-3 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors group/item">
              <div class="mr-3 mt-0.5">
                <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium">Dashboard</p>
                <p class="text-xs text-gray-400 mt-0.5">Unified marketing command center</p>
              </div>
            </a>
          </div>
        </div>

        <!-- Resources Dropdown (Blog) -->
        <div class="relative group">
          <button class="px-4 py-2 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-colors flex items-center space-x-1 text-sm font-medium">
            <span>Resources</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="absolute left-0 mt-2 w-56 bg-slate-900 border border-purple-500/20 rounded-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2">
            <!-- Resources Header -->
            <div class="px-4 py-2 border-b border-gray-800">
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Blog & Resources</p>
            </div>

            <a href="/blog" class="block px-4 py-2.5 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors text-sm">
              <span class="font-medium">📰 All Articles</span>
              <p class="text-xs text-gray-400 mt-0.5">Latest marketing insights</p>
            </a>

            <a href="/blog?category=ppc" class="block px-4 py-2.5 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors text-sm">
              <span class="font-medium">🎯 PPC Advertising</span>
              <p class="text-xs text-gray-400 mt-0.5">Meta & Google Ads guides</p>
            </a>

            <a href="/blog?category=seo" class="block px-4 py-2.5 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors text-sm">
              <span class="font-medium">🔍 SEO Optimization</span>
              <p class="text-xs text-gray-400 mt-0.5">Organic traffic strategies</p>
            </a>

            <a href="/blog?category=writing" class="block px-4 py-2.5 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors text-sm">
              <span class="font-medium">✍️ Copywriting</span>
              <p class="text-xs text-gray-400 mt-0.5">High-converting ad copy</p>
            </a>

            <a href="/blog?category=tools" class="block px-4 py-2.5 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors text-sm">
              <span class="font-medium">🛠️ Marketing Tools</span>
              <p class="text-xs text-gray-400 mt-0.5">Tool reviews & tutorials</p>
            </a>
          </div>
        </div>

        <!-- Company Dropdown -->
        <div class="relative group">
          <button class="px-4 py-2 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-colors flex items-center space-x-1 text-sm font-medium">
            <span>Company</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="absolute left-0 mt-2 w-56 bg-slate-900 border border-purple-500/20 rounded-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2">
            <!-- Company Header -->
            <div class="px-4 py-2 border-b border-gray-800">
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">About & Support</p>
            </div>

            <a href="https://app.marketingtool.pro/help" class="block px-4 py-2.5 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors text-sm">
              <span class="font-medium">📚 Help Center</span>
              <p class="text-xs text-gray-400 mt-0.5">Unified tools documentation</p>
            </a>

            <a href="/changelog" class="block px-4 py-2.5 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors text-sm">
              <span class="font-medium">📋 Changelog</span>
              <p class="text-xs text-gray-400 mt-0.5">Latest updates & features</p>
            </a>

            <a href="/affiliate" class="block px-4 py-2.5 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors text-sm">
              <span class="font-medium">🤝 Affiliate Program</span>
              <p class="text-xs text-gray-400 mt-0.5">Earn with MarketingTool</p>
            </a>

            <a href="/contact" class="block px-4 py-2.5 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors text-sm">
              <span class="font-medium">✉️ Contact Us</span>
              <p class="text-xs text-gray-400 mt-0.5">Get in touch</p>
            </a>

            <a href="/careers" class="block px-4 py-2.5 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors text-sm">
              <span class="font-medium">💼 Careers</span>
              <p class="text-xs text-gray-400 mt-0.5">Join our team</p>
            </a>

            <div class="border-t border-gray-800 mt-2 pt-2">
              <a href="/about" class="block px-4 py-2.5 text-gray-300 hover:text-white hover:bg-purple-600/20 transition-colors text-sm">
                <span class="font-medium">🏢 About Us</span>
                <p class="text-xs text-gray-400 mt-0.5">Our story & mission</p>
              </a>
            </div>
          </div>
        </div>

      </nav>

      <!-- CTA Buttons -->
      <div class="flex items-center space-x-3">
        <a href="https://app.marketingtool.pro/auth/signin" class="px-4 py-2 text-gray-300 hover:text-white transition-colors text-sm font-medium">
          Sign In
        </a>
        <a href="https://app.marketingtool.pro/auth/signup" class="px-6 py-2.5 bg-gradient-to-r from-purple-600 to-pink-600 text-white rounded-lg hover:shadow-lg hover:shadow-purple-500/50 transition-all duration-200 text-sm font-semibold">
          Free Trial
        </a>
      </div>
    </div>
  </div>
</header>

